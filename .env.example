# ============================================================
# Environment Variables Example File
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control!

# Environment (development or production)
ENVIRONMENT=development

# List of allowed origins for CORS (comma-separated without spaces)
# In production, change this to your Vercel URL
CORS_ORIGINS=http://localhost:5173

# Database Connection URL
# SQLite (Local Dev Default):
DATABASE_URL=sqlite:///./portfolio.db

# PostgreSQL (Production via Neon/Supabase):
# DATABASE_URL=postgresql://user:password@server/db

# API Key for Admin actions (Creating Blogs/Logs)
# Generate a random secure string for production
ADMIN_API_KEY=my_super_secret_local_dev_key
